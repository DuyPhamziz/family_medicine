# Database Configuration  
DB_HOST=localhost
DB_PORT=5432
DB_NAME=family_medicine_db
DB_USERNAME=postgres
DB_PASSWORD=hp12345

# Server
PORT=8080

# JWT Configuration
JWT_SECRET=ChonMotChuoiKyTuThatDaiVaBiMatOTrangNay123456789012345
JWT_EXPIRATION=43200000
JWT_REFRESH_EXPIRATION=2592000000
JWT_CLOCK_SKEW_MS=120000

# Security - CORS for Local Dev
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Refresh Cookie
REFRESH_COOKIE_SECURE=false
REFRESH_COOKIE_SAMESITE=Strict
REFRESH_COOKIE_PATH=/api/auth/refresh
REFRESH_COOKIE_NAME=refresh_token

# Rate Limiting
RATE_LIMIT_LOGIN_PER_MINUTE=5
RATE_LIMIT_PUBLIC_PER_MINUTE=60
RATE_LIMIT_AUTH_PER_MINUTE=100
RATE_LIMIT_LOGIN_LOCK_MINUTES=15

# Database
JPA_DDL_AUTO=update

# Swagger (Enable for dev)
SWAGGER_ENABLED=true
