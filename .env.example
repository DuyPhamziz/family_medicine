# Environment Variables for Family Medicine App
# Copy this file to .env and update with your values

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/family_medicine_db
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# For production, use managed database URL:
# SPRING_DATASOURCE_URL=jdbc:postgresql://your-db-host:5432/family_medicine_db

# =============================================================================
# JWT SECURITY - CHANGE THESE IN PRODUCTION!
# =============================================================================
JWT_SECRET=mySecretKeyForJWTTokenGenerationThatIsAtLeast256BitsLongForFamilyMedicineApplication
JWT_EXPIRATION=43200000
JWT_REFRESH_EXPIRATION=2592000000
JWT_CLOCK_SKEW_MS=120000

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:80,http://localhost

# For production, set to your actual domains:
# CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# =============================================================================
# COOKIE SECURITY
# =============================================================================
REFRESH_COOKIE_SECURE=false
# Set to true in production with HTTPS

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================
VITE_API_BASE_URL=http://localhost:8080

# For production:
# VITE_API_BASE_URL=https://your-backend-api.com

# =============================================================================
# SPRING PROFILES
# =============================================================================
# SPRING_PROFILES_ACTIVE=prod
# Uncomment for production deployment

